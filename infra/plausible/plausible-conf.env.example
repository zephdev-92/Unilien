# Plausible CE — fichier de config exemple
# À copier en /opt/plausible-ce/plausible-conf.env (chmod 600) puis remplir les valeurs.
# Les vraies valeurs ne doivent JAMAIS être commitées.

# URL publique du dashboard
BASE_URL=https://plausible.unilien.app

# Clés à générer une seule fois :
#   SECRET_KEY_BASE=$(openssl rand -base64 64 | tr -d '\n')
#   TOTP_VAULT_KEY=$(openssl rand -base64 32 | tr -d '\n')
SECRET_KEY_BASE=changeme-generate-with-openssl
TOTP_VAULT_KEY=changeme-generate-with-openssl

# Inscription
# - false  → registration ouverte (utiliser temporairement pour créer le 1er admin)
# - true   → registration fermée (à activer après création de l'admin)
DISABLE_REGISTRATION=false

# (Optionnel) SMTP pour envoyer les emails de confirmation / invitation
# Sans config SMTP, Plausible essaie de poster via le service `mail` interne (smtp4dev local).
# Pour la prod, brancher un vrai SMTP (Resend, AWS SES, etc.)
# MAILER_EMAIL=noreply@unilien.app
# SMTP_HOST_ADDR=smtp.resend.com
# SMTP_HOST_PORT=587
# SMTP_USER_NAME=resend
# SMTP_USER_PWD=re_xxx
