# Plausible CE v3 — fichier .env exemple
# À copier en /opt/plausible-ce/.env (chmod 600) puis remplir les valeurs.
# Les vraies valeurs ne doivent JAMAIS être commitées.

# URL publique du dashboard
BASE_URL=https://plausible.unilien.app

# Clés à générer une seule fois :
#   openssl rand -base64 48   → SECRET_KEY_BASE (≥ 64 chars)
#   openssl rand -base64 32   → TOTP_VAULT_KEY (chiffrement 2FA)
SECRET_KEY_BASE=changeme-generate-with-openssl
TOTP_VAULT_KEY=changeme-generate-with-openssl

# Inscription
# - false  → registration ouverte (utiliser temporairement pour créer le 1er admin)
# - true   → registration fermée (à activer après création de l'admin)
DISABLE_REGISTRATION=true

# Vérification email
# - sans SMTP : mettre à false pour créer le 1er admin sans email,
#   puis le supprimer (true par défaut) après création
# ENABLE_EMAIL_VERIFICATION=false

# Port HTTP interne du conteneur (mappé sur 127.0.0.1:8001 côté host via compose.override.yml)
HTTP_PORT=8000

# (Optionnel) SMTP pour envoyer les emails (invitations, confirmations, rapports)
# Sans config SMTP, Plausible n'envoie aucun email.
# MAILER_EMAIL=noreply@unilien.app
# SMTP_HOST_ADDR=smtp.resend.com
# SMTP_HOST_PORT=587
# SMTP_USER_NAME=resend
# SMTP_USER_PWD=re_xxx
